# Perix Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control

# Backend API URL
EXPO_PUBLIC_BACKEND_URL=https://api.perixapp.com

# Google Maps API Key (get from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Agora App ID (get from Agora Console)
EXPO_PUBLIC_AGORA_APP_ID=YOUR_AGORA_APP_ID

# Firebase Cloud Messaging (server key - for push notifications)
# This is used server-side only, do not expose to client
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY
