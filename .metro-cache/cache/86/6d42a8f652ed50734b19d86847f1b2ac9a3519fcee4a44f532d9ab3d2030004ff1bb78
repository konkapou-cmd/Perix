= async (token, groupCallId) => {\n    return apiRequest(`/calls/group/${groupCallId}/end`, \"POST\", token);\n  };\n\n  // Get user's group call history\n  const getMyGroupCalls = async (token, status, limit = 20) => {\n    const params = new URLSearchParams();\n    if (status) params.append(\"status\", status);\n    params.append(\"limit\", limit.toString());\n    return apiRequest(`/calls/group/my-calls?${params}`, \"GET\", token);\n  };\n\n  // Delete Profile APIs\n  const deleteBusiness = async (token, businessId) => {\n    return apiRequest(`/businesses/${businessId}`, \"DELETE\", token);\n  };\n  const deleteArtist = async (token, artistId) => {\n    return apiRequest(`/artists/${artistId}`, \"DELETE\", token);\n  };\n  const deleteUserAccount = async token => {\n    return apiRequest(\"/users/me\", \"DELETE\", token);\n  };\n\n  // Jobs API\n\n  const getJobs = async (token, params) => {\n    const searchParams = new URLSearchParams();\n    if (params?.latitude) searchParams.append(\"latitude\", String(params.latitude));\n    if (params?.longitude) searchParams.append(\"longitude\", String(params.longitude));\n    if (params?.max_distance_km) searchParams.append(\"max_distance_km\", String(params.max_distance_km));\n    if (params?.root_category) searchParams.append(\"root_category\", params.root_category);\n    if (params?.subcategory) searchParams.append(\"subcategory\", params.subcategory);\n    const query = searchParams.toString();\n    return apiRequest(`/jobs${query ? `?${query}` : \"\"}`, \"GET\", token);\n  };\n  const getJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"GET\", token);\n  };\n  const getMyJobs = async token => {\n    return apiRequest(\"/jobs/my\", \"GET\", token);\n  };\n  const createJob = async (token, job) => {\n    return apiRequest(\"/jobs\", \"POST\", token, job);\n  };\n  const updateJob = async (token, jobId, data) => {\n    return apiRequest(`/jobs/${jobId}`, \"PUT\", token, data);\n  };\n  const deleteJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"DELETE\", token);\n  };\n  const applyToJob = async (token, jobId, application) => {\n    return apiRequest(`/jobs/${jobId}/apply`, \"POST\", token, application);\n  };\n  const getJobApplications = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}/applications`, \"GET\", token);\n  };\n\n  // Activity Feed Types\n\n  const getActivityFeed = async (token, limit = 5) => {\n    return apiRequest(`/notifications/activity-feed?limit=${limit}`, \"GET\", token);\n  };\n  const markNotificationsRead = async (token, notificationIds, markAll) => {\n    return apiRequest(\"/notifications/mark-read\", \"POST\", token, {\n      notification_ids: notificationIds || [],\n      mark_all: markAll || false\n    });\n  };\n\n  // Push token registration\n  const registerPushToken = async (token, pushToken, platform) => {\n    return apiRequest(\"/users/push-token\", \"POST\", token, {\n      push_token: pushToken,\n      platform\n    });\n  };\n  const unregisterPushToken = async (token, pushToken) => {\n    return apiRequest(\"/users/push-token\", \"DELETE\", token, {\n      push_token: pushToken\n    });\n  };\n\n  // ============== PAUSE USER ==============\n\n  const pauseUser = async (token, userId) => {\n    return apiRequest(\"/users/pause\", \"POST\", token, {\n      user_id: userId\n    });\n  };\n  const unpauseUser = async (token, userId) => {\n    return apiRequest(\"/users/unpause\", \"POST\", token, {\n      user_id: userId\n    });\n  };\n  const getPausedUsers = async token => {\n    return apiRequest(\"/users/paused\", \"GET\", token);\n  };\n  const checkIfPaused = async (token, userId) => {\n    return apiRequest(`/users/${userId}/is-paused`, \"GET\", token);\n  };\n\n  // ============== REPORT USER ==============\n\n  const reportUser = async (token, userId, reason) => {\n    return apiRequest(\"/users/report\", \"POST\", token, {\n      user_id: userId,\n      reason\n