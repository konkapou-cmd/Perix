ents/${eventId}/messages`, \"GET\", token);\n  };\n  const sendEventMessage = async (token, eventId, text) => {\n    return apiRequest(`/events/${eventId}/messages`, \"POST\", token, {\n      text\n    });\n  };\n  const getActivities = async token => {\n    return apiRequest(\"/activities\", \"GET\", token);\n  };\n  const createActivity = async (token, payload) => {\n    return apiRequest(\"/activities\", \"POST\", token, payload);\n  };\n  const updateActivity = async (token, activityId, payload) => {\n    return apiRequest(`/activities/${activityId}`, \"PUT\", token, payload);\n  };\n  const deleteActivity = async (token, activityId) => {\n    return apiRequest(`/activities/${activityId}`, \"DELETE\", token);\n  };\n  const getActivityDetail = async (token, activityId) => {\n    return apiRequest(`/activities/${activityId}`, \"GET\", token);\n  };\n  const joinActivityByCode = async (token, invitationCode) => {\n    return apiRequest(\"/activities/join-by-code\", \"POST\", token, {\n      invitation_code: invitationCode\n    });\n  };\n  const rsvpActivity = async (token, activityId, status) => {\n    return apiRequest(`/activities/${activityId}/rsvp`, \"POST\", token, {\n      status\n    });\n  };\n  const getHomeFeed = async (token, location, maxDistanceKm, mapBounds) => {\n    const params = new URLSearchParams();\n    if (location) {\n      params.append(\"latitude\", location.latitude.toString());\n      params.append(\"longitude\", location.longitude.toString());\n    }\n    if (maxDistanceKm) {\n      params.append(\"radius_km\", maxDistanceKm.toString());\n    }\n    if (mapBounds) {\n      params.append(\"min_lat\", mapBounds.minLat.toString());\n      params.append(\"max_lat\", mapBounds.maxLat.toString());\n      params.append(\"min_lng\", mapBounds.minLng.toString());\n      params.append(\"max_lng\", mapBounds.maxLng.toString());\n    }\n    const query = params.toString() ? `?${params.toString()}` : \"\";\n    return apiRequest(`/feed/home${query}`, \"GET\", token);\n  };\n  const getUserAttendance = async (token, userId) => {\n    return apiRequest(`/users/${userId}/attendance`, \"GET\", token);\n  };\n\n  // ============================================\n  // AGORA VOICE/VIDEO CALLS\n  // ============================================\n\n  const generateCallToken = async (token, channel, uid, role) => {\n    return apiRequest(\"/calls/token\", \"POST\", token, {\n      channel,\n      uid: uid || 0,\n      role: role || 1\n    });\n  };\n  const initiateCall = async (token, toUserId, callType = \"video\", toBusinessId) => {\n    return apiRequest(\"/calls/initiate\", \"POST\", token, {\n      to_user_id: toUserId,\n      to_business_id: toBusinessId,\n      call_type: callType\n    });\n  };\n  const answerCall = async (token, callId) => {\n    return apiRequest(`/calls/answer/${callId}`, \"POST\", token);\n  };\n  const endCall = async (token, callId) => {\n    return apiRequest(`/calls/end/${callId}`, \"POST\", token);\n  };\n  const rejectCall = async (token, callId) => {\n    return apiRequest(`/calls/reject/${callId}`, \"POST\", token);\n  };\n  const getCallStatus = async (token, callId) => {\n    return apiRequest(`/calls/status/${callId}`, \"GET\", token);\n  };\n  const getPendingCalls = async token => {\n    return apiRequest(\"/calls/pending\", \"GET\", token);\n  };\n  const getCallHistory = async token => {\n    return apiRequest(\"/calls/history\", \"GET\", token);\n  };\n\n  // Agora App ID (public, safe to expose)\n  const AGORA_APP_ID = \"7793967d595046f08f88fed156f8be42\";\n\n  // =============================================================================\n  // GROUP CALLS API\n  // =============================================================================\n\n  // Create a group call\n  const createGroupCall = async (token, participantIds, callType = \"video\", groupName) => {\n    return apiRequest(\"/calls/group/create\", \"POST\", token, {\n      participant_ids: participantIds,\n      call_type: callType,\n      group_name: groupName\n    });\n  };\n\n  // Get group call details\n  const getGroupCall = async (token, groupCallId) => {\n    return apiRequest(`/calls/group/${groupCallId}`, \"GET\", token);\n  };\n\n  // Join a group call\n  const joinGroupCall = async (token, groupCallId) => {\n    return apiRequest(`/calls/group/${groupCallId}/join`, \"POST\", token);\n  };\n\n  // Add participant to active group call\n  const addParticipantToGroupCall = async (token, groupCallId, userId) => {\n    return apiRequest(`/calls/group/${groupCallId}/add-participant`, \"POST\", token, {\n      user_id: userId\n    });\n  };\n\n  // Leave a group call\n  const leaveGroupCall = async (token, groupCallId) => {\n    return apiRequest(`/calls/group/${groupCallId}/leave`, \"POST\", token);\n  };\n\n  // End a group call (host only)\n  const endGroupCall = async (token, groupCallId) => {\n    return apiRequest(`/calls/group/${groupCallId}/end`, \"POST\", token);\n  };\n\n  // Get user's group call history\n  const getMyGroupCalls = async (token, status, limit = 20) => {\n    const params = new URLSearchParams();\n    if (status) params.append(\"status\", status);\n    params.append(\"limit\", limit.toString());\n    return apiRequest(`/calls/group/my-calls?${params}`, \"GET\", token);\n  };\n\n  // Delete Profile APIs\n  const deleteBusiness = async (token, businessId) => {\n    return apiRequest(`/businesses/${businessId}`, \"DELETE\", token);\n  };\n  const deleteArtist = async (token, artistId) => {\n    return apiRequest(`/artists/${artistId}`, \"DELETE\", token);\n  };\n  const deleteUserAccount = async token => {\n    return apiRequest(\"/users/me\", \"DELETE\", token);\n  };\n\n  // Jobs API\n\n  const getJobs = async (token, params) => {\n    const searchParams = new URLSearchParams();\n    if (params?.latitude) searchParams.append(\"latitude\", String(params.latitude));\n    if (params?.longitude) searchParams.append(\"longitude\", String(params.longitude));\n    if (params?.max_distance_km) searchParams.append(\"max_distance_km\", String(params.max_distance_km));\n    if (params?.root_category) searchParams.append(\"root_category\", params.root_category);\n    if (params?.subcategory) searchParams.append(\"subcategory\", params.subcategory);\n    const query = searchParams.toString();\n    return apiRequest(`/jobs${query ? `?${query}` : \"\"}`, \"GET\", token);\n  };\n  const getJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"GET\", token);\n  };\n  const getMyJobs = async token => {\n    return apiRequest(\"/jobs/my\", \"GET\", token);\n  };\n  const createJob = async (token, job) => {\n    return apiRequest(\"/jobs\", \"POST\", token, job);\n  };\n  const updateJob = async (token, jobId, data) => {\n    return apiRequest(`/jobs/${jobId}`, \"PUT\", token, data);\n  };\n  const deleteJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"DELETE\", token);\n  };\n  const applyToJob = async (token, jobId, application) => {\n    return apiRequest(`/jobs/${jobId}/apply`, \"POST\", token, application);\n  };\n  const getJobApplications = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}/applications`, \"GET\", token);\n  };\n\n  // Activity Feed Types\n\n  const getActivityFeed = async (token, limit = 5) => {\n    return apiRequest(`/notifications/activity-feed?limit=${limit}`, \"GET\", token);\n  };\n  const markNotificationsRead = async (token, notificationIds, markAll) => {\n    return apiRequest(\"/notifications/mark-read\", \"POST\", token, {\n      notification_ids: notificationIds || [],\n      mark_all: markAll || false\n    });\n  };\n\n  // Push token registration\n  const registerPushToken = async (token, pushToken, platform) => {\n    return apiRequest(\"/users/push-token\", \"POST\", token, {\n      push_token: pushToken,\n      platform\n    });\n  };\n  const unregisterPushToken = async (token, pushToken) => {\n    return apiRequest(\"/us