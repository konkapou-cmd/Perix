ory\", params.root_category);\n    if (params?.subcategory) searchParams.append(\"subcategory\", params.subcategory);\n    const query = searchParams.toString();\n    return apiRequest(`/jobs${query ? `?${query}` : \"\"}`, \"GET\", token);\n  };\n  const getJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"GET\", token);\n  };\n  const getMyJobs = async token => {\n    return apiRequest(\"/jobs/my\", \"GET\", token);\n  };\n  const createJob = async (token, job) => {\n    return apiRequest(\"/jobs\", \"POST\", token, job);\n  };\n  const updateJob = async (token, jobId, data) => {\n    return apiRequest(`/jobs/${jobId}`, \"PUT\", token, data);\n  };\n  const deleteJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"DELETE\", token);\n  };\n  const applyToJob = async (token, jobId, application) => {\n    return apiRequest(`/jobs/${jobId}/apply`, \"POST\", token, application);\n  };\n  const getJobApplications = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}/applications`, \"GET\", token);\n  };\n\n  // Activity Feed Types\n\n  const getActivityFeed = async (token, limit = 5) => {\n    return apiRequest(`/notifications/activity-feed?limit=${limit}`, \"GET\", token);\n  };\n  const markNotificationsRead = async (token, notificationIds, markAll) => {\n    return apiRequest(\"/notifications/mark-read\", \"POST\", token, {\n      notification_ids: notificationIds || [],\n      mark_all: markAll || false\n    });\n  };\n\n  // Push token registration\n  const registerPushToken = async (token, pushToken, platform) => {\n    return apiRequest(\"/users/push-token\", \"POST\", token, {\n      push_token: pushToken,\n      platform\n    });\n  };\n  const unregisterPushToken = async (token, pushToken) => {\n    return apiRequest(\"/users/push-token\", \"DELETE\", token, {\n      push_token: pushToken\n    });\n  };\n\n  // ============== PAUSE USER ==============\n\n  const pauseUser = async (token, userId) => {\n    return apiRequest(\"/users/pause\", \"POST\", token, {\n      user_id: userId\n    });\n  };\n  const unpauseUser = async (token, userId) => {\n    return apiRequest(\"/users/unpause\", \"POST\", token, {\n      user_id: userId\n    });\n  };\n  const getPausedUsers = async token => {\n    return apiRequest(\"/users/paused\", \"GET\", token);\n  };\n  const checkIfPaused = async (token, userId) => {\n    return apiRequest(`/users/${userId}/is-paused`, \"GET\", token);\n  };\n\n  // ============== REPORT USER ==============\n\n  const reportUser = async (token, userId, reason) => {\n    return apiRequest(\"/users/report\", \"POST\", token, {\n      user_id: userId,\n      reason\n    });\n  };\n\n  // Report a business\n  const reportBusiness = async (token, businessId, reason) => {\n    return apiRequest(`/businesses/${businessId}/report`, \"POST\", token, {\n      reason\n    });\n  };\n\n  // Report an artist\n  const reportArtist = async (token, artistId, reason) => {\n    return apiRequest(`/artists/${artistId}/report`, \"POST\", token, {\n      reason\n    });\n  };\n\n  // ============== CHAT ENHANCEMENTS ==============\n\n  // Set typing status\n  const setTypingStatus = async (token, toUserId, isTyping) => {\n    return apiRequest(\"/messages/typing\", \"POST\", token, {\n      to_user_id: toUserId,\n      is_typing: isTyping\n    });\n  };\n\n  // Get typing status of another user\n  const getTypingStatus = async (token, otherUserId) => {\n    return apiRequest(`/messages/typing/${otherUserId}`, \"GET\", token);\n  };\n\n  // Send media message\n  const sendMediaMessage = async (token, toUserId, mediaUrl, mediaType, text) => {\n    return apiRequest(\"/messages/media\", \"POST\", token, {\n      to_user_id: toUserId,\n      media_url: mediaUrl,\n      media_type: mediaType,\n      text: text || \"\"\n    });\n  };\n\n  // Get message read status\n  const getMessageReadStatus = async (token, messageId) => {\n    return apiRequest(`/messages/read-status/