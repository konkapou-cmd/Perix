   business_id: businessId\n    });\n  };\n  const checkVoucher = async voucherCode => {\n    return apiRequest(`/subscriptions/voucher/check/${encodeURIComponent(voucherCode)}`, \"GET\");\n  };\n\n  // ============== GEOSPATIAL SEARCH ==============\n\n  /**\n   * Search for artists and their posts within a radius of a city or coordinates.\n   * @param token - Session token\n   * @param city - City name to search around (will be geocoded)\n   * @param latitude - Optional latitude for center point\n   * @param longitude - Optional longitude for center point\n   * @param radiusKm - Search radius in kilometers (default 25)\n   */\n  const searchNearby = async (token, city, latitude, longitude, radiusKm = 25) => {\n    const params = new URLSearchParams();\n    if (city) params.append(\"city\", city);\n    if (latitude !== undefined) params.append(\"latitude\", latitude.toString());\n    if (longitude !== undefined) params.append(\"longitude\", longitude.toString());\n    params.append(\"radius_km\", radiusKm.toString());\n    return apiRequest(`/search/nearby?${params.toString()}`, \"GET\", token);\n  };\n\n  /**\n   * Search artists by city name within a radius.\n   * @param token - Session token\n   * @param cityName - City name to search\n   * @param radiusKm - Search radius in kilometers (default 25)\n   */\n  const searchArtistsByCity = async (token, cityName, radiusKm = 25) => {\n    return apiRequest(`/search/artists/city/${encodeURIComponent(cityName)}?radius_km=${radiusKm}`, \"GET\", token);\n  };\n\n  // ============== CONTACTS & REFERRALS ==============\n\n  const checkContacts = async (token, contacts) => {\n    return apiRequest(\"/contacts/check\", \"POST\", token, {\n      contacts\n    });\n  };\n  const trackInvite = async (token, phoneNumber, inviteMethod) => {\n    return apiRequest(`/contacts/invite-tracking?phone_number=${encodeURIComponent(phoneNumber)}&invite_method=${inviteMethod}`, \"POST\", token);\n  };\n  const getMyInvites = async token => {\n    return apiRequest(\"/contacts/my-invites\", \"GET\", token);\n  };\n  const getReferralCode = async token => {\n    return apiRequest(\"/contacts/referral-code\", \"GET\", token);\n  };\n  const applyReferralCode = async (token, referralCode) => {\n    return apiRequest(`/contacts/apply-referral?referral_code=${encodeURIComponent(referralCode)}`, \"POST\", token);\n  };\n\n  // ==================== Analytics ====================\n\n  const getUserAnalytics = async (token, days = 30) => {\n    return apiRequest(`/analytics/user?days=${days}`, \"GET\", token);\n  };\n  const getArtistAnalytics = async (token, artistId, days = 30) => {\n    return apiRequest(`/analytics/artist/${artistId}?days=${days}`, \"GET\", token);\n  };\n  const getBusinessAnalytics = async (token, businessId, days = 30) => {\n    return apiRequest(`/analytics/business/${businessId}?days=${days}`, \"GET\", token);\n  };\n  const trackProfileView = async (token, viewedUserId, viewedArtistId, viewedBusinessId) => {\n    const params = new URLSearchParams();\n    if (viewedUserId) params.append(\"viewed_user_id\", viewedUserId);\n    if (viewedArtistId) params.append(\"viewed_artist_id\", viewedArtistId);\n    if (viewedBusinessId) params.append(\"viewed_business_id\", viewedBusinessId);\n    return apiRequest(`/analytics/track-view?${params.toString()}`, \"POST\", token);\n  };\n\n  // ==================== Read Receipts ====================\n\n  const markMessagesAsRead = async (token, otherUserId) => {\n    return apiRequest(`/messages/mark-read/${otherUserId}`, \"POST\", token);\n  };\n  const getUnreadCount = async token => {\n    return apiRequest(\"/messages/unread-count\", \"GET\", token);\n  };\n});","lineCount":2459,"map":[[12,2,291,0,"Object"],[12,8,291,0],[12,9,291,0,"defineProperty"],[12,23,291,0],[12,24,291,0,"exports"],[12,31,291,0],[13,4,291,0,"enumerable"],[13,14,291,0],[14,4,291,0,"get"],[14,7,291,0],[14,18,291,0,"get"],[14,19,291,0],[15,6,291,0],[15,13,291,0,"ACTIVITY_THEME