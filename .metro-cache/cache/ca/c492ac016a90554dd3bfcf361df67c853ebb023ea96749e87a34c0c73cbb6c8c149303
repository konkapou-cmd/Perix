s.append(\"root_category\", params.root_category);\n    if (params?.subcategory) searchParams.append(\"subcategory\", params.subcategory);\n    const query = searchParams.toString();\n    return apiRequest(`/jobs${query ? `?${query}` : \"\"}`, \"GET\", token);\n  };\n  const getJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"GET\", token);\n  };\n  const getMyJobs = async token => {\n    return apiRequest(\"/jobs/my\", \"GET\", token);\n  };\n  const createJob = async (token, job) => {\n    return apiRequest(\"/jobs\", \"POST\", token, job);\n  };\n  const updateJob = async (token, jobId, data) => {\n    return apiRequest(`/jobs/${jobId}`, \"PUT\", token, data);\n  };\n  const deleteJob = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}`, \"DELETE\", token);\n  };\n  const applyToJob = async (token, jobId, application) => {\n    return apiRequest(`/jobs/${jobId}/apply`, \"POST\", token, application);\n  };\n  const getJobApplications = async (token, jobId) => {\n    return apiRequest(`/jobs/${jobId}/applications`, \"GET\", token);\n  };\n\n  // Activity Feed Types\n\n  const getActivityFeed = async (token, limit = 5) => {\n    return apiRequest(`/notifications/activity-feed?limit=${limit}`, \"GET\", token);\n  };\n  const markNotificationsRead = async (token, notificationIds, markAll) => {\n    return apiRequest(\"/notifications/mark-read\", \"POST\", token, {\n      notification_ids: notificationIds || [],\n      mark_all: markAll || false\n    });\n  };\n\n  // Push token registration\n  const registerPushToken = async (token, pushToken, platform) => {\n    return apiRequest(\"/users/push-token\", \"POST\", token, {\n      push_token: pushToken,\n      platform\n    });\n  };\n  const unregisterPushToken = async (token, pushToken) => {\n    return apiRequest(\"/users/push-token\", \"DELETE\", token, {\n      push_token: pushToken\n    });\n  };\n\n  // ============== PAUSE USER ==============\n\n  const pauseUser = async 