    flexDirection: "row",
    alignItems: "center",
    marginBottom: 10,
  },
  calendarEventsSection: {
    backgroundColor: "#fff",
    borderTopWidth: 1,
    borderTopColor: "#e5e7eb",
    paddingHorizontal: 16,
    paddingTop: 16,
    paddingBottom: 24,
  },
  calendarEventsTitle: {
