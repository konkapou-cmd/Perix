    width: "100%",
    height: "100%",
  },
seeAllLink: {
    color: "#000000",
    fontSize: 12,
    fontWeight: "600",
  },
  postInput: {
    minHeight: 90,
    borderWidth: 1,
    borderColor: "#e5e7eb",
